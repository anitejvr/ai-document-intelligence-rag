{
  "family": "ai-document-intelligence-rag-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::207791567970:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "ai-document-intelligence-rag-container",
      "image": "207791567970.dkr.ecr.us-east-1.amazonaws.com/ai-document-intelligence-rag:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "FLASK_SECRET_KEY",
          "value": "temporary-dev-secret-key"
        }
      ],
      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:207791567970:secret:openai-api-key-T2Ofjj"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-document-intelligence-rag",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}